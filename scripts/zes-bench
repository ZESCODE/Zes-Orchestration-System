    "provider_bench": {
        "url": os.environ.get("PROV_BENCH_URL", "https://api.groq.com/openai/v1/chat/completions"),
        "model": os.environ.get("PROV_BENCH_MODEL", "llama-3.3-70b-versatile"),
        "env_key": "GROQ_API_KEY",
        "name": "Provider Benchmarker (Groq Llama 3.3)",
    },
    "service_bench": {
        "url": os.environ.get("SVC_BENCH_URL", "https://openrouter.ai/api/v1/chat/completions"),
        "model": os.environ.get("SVC_BENCH_MODEL", "deepseek/deepseek-v4-flash"),
        "env_key": "OPENROUTER_API_KEY",
        "name": "Service Benchmarker (OpenRouter DeepSeek V4)",
    },
    "resource_monitor": {
        "url": os.environ.get("RESOURCE_URL", "https://api.llm7.io/v1/chat/completions"),
        "model": os.environ.get("RESOURCE_MODEL", "codestral-latest"),
        "env_key": "LLM7_API_KEY",
        "name": "Resource Monitor (LLM7 Codestral)",
    },
}

